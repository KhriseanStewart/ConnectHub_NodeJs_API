PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/connecthub

# JWT auth
JWT_SECRET=super_secret_key
JWT_EXPIRES_IN=7d

# OTP (password reset) – pepper hashes OTP in DB; set a random string for production
# OTP_PEPPER=your_random_otp_pepper_string

# Mailtrap / email (password reset)
# Development: Mailtrap Email Testing → Inboxes → SMTP Settings
MAIL_USER=your_mailtrap_username
MAIL_PASS=your_mailtrap_password
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
# Optional: sender address
# EMAIL_FROM=ConnectHub <noreply@connecthub.local>

# Production SMTP (when NODE_ENV=production)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=ConnectHub <noreply@yourdomain.com>

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=connecthub
R2_PUBLIC_BASE_URL=https://your-public-domain-or-r2-public-url